// ═══════════════════════════════════════════
//  THRESHOLD CHECK
//  Stability-gated: returns early until
//  STABLE_SAMPLES_REQUIRED valid cycles pass
// ═══════════════════════════════════════════
void mqtt_check_thresholds() {
  if (!measurementStable) return;

  // Use smoothed values only — bat and sig excluded intentionally
  bool hrLow   = hrSmoothed > 0   && hrSmoothed   < ALERT_HR_LOW;
  bool hrHigh  = hrSmoothed > 0   && hrSmoothed   > ALERT_HR_HIGH;
  bool spo2Low = spo2Smoothed > 0 && spo2Smoothed < ALERT_SPO2_LOW;
  bool tempLow = bodyTemp > 0     && bodyTemp      < ALERT_TEMP_LOW;
  bool tempHigh = bodyTemp > 0    && bodyTemp      > ALERT_TEMP_HIGH;

  if (hrLow || hrHigh || spo2Low || tempLow || tempHigh) {
    consecBadCount++;

    // Require ALERT_CONSEC_REQUIRED consecutive bad readings before firing
    if (consecBadCount < ALERT_CONSEC_REQUIRED) {
      Serial.print(F("[THRESHOLD] Bad reading "));
      Serial.print(consecBadCount);
      Serial.print(F("/"));
      Serial.print(ALERT_CONSEC_REQUIRED);
      Serial.println(F(" — waiting to confirm"));
      return;
    }

    if (tempHigh)     snprintf(thresholdReason, sizeof(thresholdReason), "FEVER: TEMP %.1fC", (double)bodyTemp);
    else if (tempLow) snprintf(thresholdReason, sizeof(thresholdReason), "LOW TEMP: %.1fC", (double)bodyTemp);
    else if (spo2Low) snprintf(thresholdReason, sizeof(thresholdReason), "LOW SpO2: %d%%", spo2Smoothed);
    else if (hrHigh)  snprintf(thresholdReason, sizeof(thresholdReason), "HIGH HR: %.0f BPM", hrSmoothed);
    else              snprintf(thresholdReason, sizeof(thresholdReason), "LOW HR: %.0f BPM", hrSmoothed);

    Serial.print(F("[ALERT] CONFIRMED: "));
    Serial.println(thresholdReason);

    if (!thresholdActive) {
      thresholdActive = true;
      beep(2, 300, 150);
      updateSOSStatus(false, 0);
      clearZoneBG(42, 242, 196, 12);
      tft.setTextSize(1);
      tft.setTextColor(C_ORANGE);
      tft.setCursor(42, 244);
      tft.print(thresholdReason);
      mqtt_publish_alert("THRESHOLD");
      gsm_send_threshold_alert();
    }
  } else {
    consecBadCount = 0;
    if (thresholdActive) {
      thresholdActive = false;
      Serial.println(F("[ALERT] Vitals back to normal"));
      updateSOSStatus(false, 0);
    }
  }
}

