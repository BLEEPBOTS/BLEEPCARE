// ═══════════════════════════════════════════
//  GSM — robust sendAT
// ═══════════════════════════════════════════
String sendAT(const char* cmd, unsigned long waitMs = 3000) {
  while (sim900.available()) sim900.read();

  Serial.print("\n>> ");
  Serial.println(cmd);

  sim900.println(cmd);

  String response;
  unsigned long start = millis();

  while (millis() - start < waitMs) {
    while (sim900.available()) {
      char c = sim900.read();
      response += c;
    }
  }

  response.trim();
  Serial.print("<< ");
  Serial.println(response);

  return response;
}

// ═══════════════════════════════════════════
//  GSM — strong initSIM900
// ═══════════════════════════════════════════
bool initSIM900() {
  Serial.println("\n=== SIM900 INIT ===");

  delay(3000);

  for (int i = 0; i < 5; i++) {
    String r = sendAT("AT", 2000);
    if (r.indexOf("OK") != -1) break;
    delay(1500);
    if (i == 4) return false;
  }

  sendAT("ATE0");
  sendAT("AT+CMGF=1");
  sendAT("AT+CSQ");

  for (int i = 0; i < 20; i++) {
    String r = sendAT("AT+CREG?", 2000);
    if (r.indexOf(",1") != -1 || r.indexOf(",5") != -1) {
      Serial.println("NETWORK OK");
      return true;
    }
    delay(2000);
  }

  Serial.println("NETWORK FAIL");
  return false;
}

// ═══════════════════════════════════════════
//  GSM — safe SMS
//  FIX 4: now reads modem response after
//  sending and logs +CMGS / ERROR to Serial
// ═══════════════════════════════════════════
void gsm_send_sms(const char* number, const char* message) {
  if (!sim900Ready) {
    Serial.println("[SMS] GSM unavailable");
    return;
  }

  // FIX 3: log message length before sending so truncation is visible
  Serial.print("[SMS] Length = ");
  Serial.println(strlen(message));
  Serial.println("[SMS] Sending");

  sendAT("AT+CMGF=1");

  sim900.print("AT+CMGS=\"");
  sim900.print(number);
  sim900.println("\"");

  delay(1500);

  sim900.print(message);
  delay(500);
  sim900.write(26);  // CTRL+Z

  // FIX 4: read and log modem response — look for +CMGS or ERROR
  String smsResponse = "";
  unsigned long start = millis();
  while (millis() - start < 15000) {
    while (sim900.available()) {
      smsResponse += (char)sim900.read();
    }
  }
  smsResponse.trim();
  Serial.print("[SMS] Modem response: ");
  Serial.println(smsResponse);

  if (smsResponse.indexOf("+CMGS") != -1) {
    Serial.println("[SMS] Confirmed sent OK");
  } else if (smsResponse.indexOf("ERROR") != -1) {
    Serial.println("[SMS] ERROR — message rejected by modem");
  } else {
    Serial.println("[SMS] No confirmation received");
  }

  delay(2000);
}

// ═══════════════════════════════════════════
//  GSM — clean call
// ═══════════════════════════════════════════
void gsm_make_call(const char* number) {
  if (!sim900Ready) {
    Serial.println("[CALL] GSM unavailable");
    return;
  }
  Serial.println("[CALL] Dialing");

  String cmd = String("ATD") + number + ";";
  sendAT(cmd.c_str(), 3000);

  delay(10000);
  sendAT("ATH");
  Serial.println("[CALL] Ended");
}

// ═══════════════════════════════════════════
//  GSM — SOS alert
//  NOT stability-gated — fires immediately
//  for panic button and fall/collision events
// ═══════════════════════════════════════════
void gsm_send_sos_alert() {
  // FIX 5: use dtostrf for GPS coords to avoid heavy float formatting
  char latStr[16], lonStr[16];
  dtostrf(gpsFix ? gpsLat : 0.0, 0, 6, latStr);
  dtostrf(gpsFix ? gpsLon : 0.0, 0, 6, lonStr);

  // FIX 1+2: short message, no degree symbol, safe ASCII only
  char msg[160];
  if (gpsFix) {
    snprintf(msg, sizeof(msg),
             "SOS! TRISHA NEEDS HELP!\n"
             "HR:%d BPM SpO2:%d%%\n"
             "Temp:%.1fC\n"
             "Location:https://maps.google.com/?q=%s,%s",
             (int)bpmDisplay, spo2Value, (double)bodyTemp,
             latStr, lonStr);
  } else {
    snprintf(msg, sizeof(msg),
             "SOS! TRISHA NEEDS HELP!\n"
             "HR:%d BPM SpO2:%d%%\n"
             "Temp:%.1fC\n"
             "Location: https://maps.google.com/?q=%s,%s",
             (int)bpmDisplay, spo2Value, (double)bodyTemp);
  }

  // FIX 3: log length before send
  Serial.print("[SOS SMS] Length = ");
  Serial.println(strlen(msg));

  gsm_send_sms(CAREGIVER_NUMBER, msg);
  delay(3000);
  gsm_make_call(CAREGIVER_NUMBER);
}

// ═══════════════════════════════════════════
//  GSM — threshold alert
//  Stability-gated: only fires after
//  STABLE_SAMPLES_REQUIRED valid cycles
// ═══════════════════════════════════════════
void gsm_send_threshold_alert() {
  if (!measurementStable) {
    Serial.println("[GSM] Skipped - system still stabilizing");
    return;
  }

  // FIX 5: use dtostrf for GPS coords
  char latStr[16], lonStr[16];
  dtostrf(gpsFix ? gpsLat : 0.0, 0, 6, latStr);
  dtostrf(gpsFix ? gpsLon : 0.0, 0, 6, lonStr);

  // FIX 2: no degree symbol — plain ASCII only
  const char* tempLabel;
  if (bodyTemp < ALERT_TEMP_LOW) tempLabel = "LOW";
  else if (bodyTemp > ALERT_TEMP_HIGH) tempLabel = "HIGH";
  else tempLabel = "ABNORMAL";

  // FIX 1: short message well within 160-char SMS limit, safe ASCII
  char msg[160];
  snprintf(msg, sizeof(msg),
           "TRISHA NEEDS HELP!\n"
           "Temp:%s %.1fC\n"
           "HR:%d BPM\n"
           "SpO2:%d%% %s\n"
           "GPS:https://maps.google.com/?q=%s,%s",
           tempLabel, (double)bodyTemp,
           (int)bpmDisplay,
           spo2Value, (spo2Value < 95 ? "LOW" : "OK"),
           latStr, lonStr);

  // FIX 3: log length before send
  Serial.print("[THRESHOLD SMS] Length = ");
  Serial.println(strlen(msg));

  gsm_send_sms(CAREGIVER_NUMBER, msg);
  delay(3000);
  gsm_make_call(CAREGIVER_NUMBER);
}

// ═══════════════════════════════════════════
//  WiFi + MQTT  (primary path)
// ═══════════════════════════════════════════

// ═══════════════════════════════════════════
//  GSM GPRS MQTT  (fallback path)
//
//  The SIM900 does not support TCP/IP via AT
//  commands by default on all firmware builds,
//  but the standard SIM900 firmware includes
//  the AT+CIPSTART / AT+CIPSEND command set.
//  We use it to open a raw TCP socket to the
//  HiveMQ public broker and send a minimal
//  hand-crafted MQTT CONNECT + PUBLISH frame.
//
//  Frame layout follows MQTT 3.1.1 spec:
//    CONNECT  — fixed header 0x10, variable
//               header + "MQTT" protocol name
//    PUBLISH  — fixed header 0x30, topic, payload
// ═══════════════════════════════════════════

// Build a minimal MQTT CONNECT packet into buf.
// Returns number of bytes written.
int buildMQTTConnect(uint8_t* buf, const char* clientId) {
  // Protocol name "MQTT" + level 4 + flags + keepalive 60s
  const char* proto = "MQTT";
  uint8_t protoLen  = 4;
  uint8_t clientIdLen = strlen(clientId);

  // Variable header: 2(proto len) + 4(proto name) + 1(level) + 1(flags) + 2(keepalive)
  uint8_t varHeader[10] = {
    0x00, protoLen,                   // protocol name length
    'M','Q','T','T',                  // protocol name
    0x04,                             // protocol level (MQTT 3.1.1)
    0x02,                             // connect flags: clean session
    0x00, 0x3C                        // keepalive = 60s
  };

  // Payload: 2-byte length prefix + clientId
  uint8_t remaining = 10 + 2 + clientIdLen;

  int i = 0;
  buf[i++] = 0x10;          // CONNECT fixed header
  buf[i++] = remaining;     // remaining length (simple, <128)
  for (int j = 0; j < 10; j++) buf[i++] = varHeader[j];
  buf[i++] = 0x00;
  buf[i++] = clientIdLen;
  for (int j = 0; j < clientIdLen; j++) buf[i++] = clientId[j];
  return i;
}

// Build a minimal MQTT PUBLISH packet (QoS 0) into buf.
// Returns number of bytes written.
int buildMQTTPublish(uint8_t* buf, const char* topic, const char* payload) {
  uint8_t topicLen   = strlen(topic);
  uint16_t payloadLen = strlen(payload);

  // Remaining length = 2 + topicLen + payloadLen
  uint16_t remaining = 2 + topicLen + payloadLen;

  int i = 0;
  buf[i++] = 0x30;                    // PUBLISH, QoS 0, no retain
  // Encode remaining length (MQTT variable-length encoding)
  if (remaining < 128) {
    buf[i++] = (uint8_t)remaining;
  } else {
    buf[i++] = (remaining & 0x7F) | 0x80;
    buf[i++] = remaining >> 7;
  }
  buf[i++] = 0x00;
  buf[i++] = topicLen;
  for (int j = 0; j < topicLen; j++)   buf[i++] = topic[j];
  for (int j = 0; j < payloadLen; j++) buf[i++] = payload[j];
  return i;
}

// Wait for a specific string in SIM900 response within timeoutMs.
bool simWaitFor(const char* expect, unsigned long timeoutMs = 5000) {
  String resp = "";
  unsigned long start = millis();
  while (millis() - start < timeoutMs) {
    while (sim900.available()) {
      resp += (char)sim900.read();
      if (resp.indexOf(expect) != -1) return true;
    }
  }
  Serial.print(F("[GSM-MQTT] Expected '"));
  Serial.print(expect);
  Serial.print(F("' got: "));
  Serial.println(resp);
  return false;
}

// Bring up GPRS and publish one MQTT packet, then tear down.
// Returns true on success.
bool gsm_mqtt_publish(const char* topic, const char* payload) {
  if (!sim900Ready) {
    Serial.println(F("[GSM-MQTT] GSM not ready"));
    return false;
  }

  Serial.println(F("[GSM-MQTT] Starting GPRS publish..."));

  // ── 1. Attach GPRS ───────────────────────────────────────────────
  sendAT("AT+CGATT=1", 3000);

  // ── 2. Set APN and bring up wireless connection ──────────────────
  sendAT("AT+CIPMUX=0", 2000);     // single connection mode
  sendAT("AT+CIPSHUT", 3000);      // close any leftover session

  String sapbr = String("AT+CSTT=\"") + GPRS_APN + "\"";
  sendAT(sapbr.c_str(), 2000);
  sendAT("AT+CIICR", 5000);        // bring up wireless connection

  String ip = sendAT("AT+CIFSR", 3000);
  Serial.print(F("[GSM-MQTT] IP: "));
  Serial.println(ip);
  if (ip.indexOf("ERROR") != -1) {
    Serial.println(F("[GSM-MQTT] Failed to get IP — GPRS attach failed"));
    return false;
  }

  // ── 3. Open TCP socket to broker ────────────────────────────────
  String cipstart = String("AT+CIPSTART=\"TCP\",\"") +
                    GSM_MQTT_HOST + "\"," + GSM_MQTT_PORT;
  sendAT(cipstart.c_str(), 2000);

  if (!simWaitFor("CONNECT OK", 10000)) {
    Serial.println(F("[GSM-MQTT] TCP connect failed"));
    sendAT("AT+CIPSHUT", 2000);
    return false;
  }
  Serial.println(F("[GSM-MQTT] TCP connected"));

  // ── 4. Send MQTT CONNECT frame ───────────────────────────────────
  char clientId[32];
  snprintf(clientId, sizeof(clientId), "%s_%lu", DEVICE_ID, millis() % 10000);

  uint8_t connectFrame[64];
  int connectLen = buildMQTTConnect(connectFrame, clientId);

  String cipsendCmd = String("AT+CIPSEND=") + connectLen;
  sendAT(cipsendCmd.c_str(), 2000);
  if (!simWaitFor(">", 3000)) {
    Serial.println(F("[GSM-MQTT] No prompt for CONNECT frame"));
    sendAT("AT+CIPSHUT", 2000);
    return false;
  }
  sim900.write(connectFrame, connectLen);
  delay(1500);  // wait for CONNACK

  // ── 5. Send MQTT PUBLISH frame ───────────────────────────────────
  uint8_t publishFrame[512];
  int publishLen = buildMQTTPublish(publishFrame, topic, payload);

  cipsendCmd = String("AT+CIPSEND=") + publishLen;
  sendAT(cipsendCmd.c_str(), 2000);
  if (!simWaitFor(">", 3000)) {
    Serial.println(F("[GSM-MQTT] No prompt for PUBLISH frame"));
    sendAT("AT+CIPSHUT", 2000);
    return false;
  }
  sim900.write(publishFrame, publishLen);

  // Wait for SEND OK
  bool sent = simWaitFor("SEND OK", 5000);
  Serial.println(sent ? F("[GSM-MQTT] Publish OK") : F("[GSM-MQTT] Publish timeout"));

  // ── 6. Tear down TCP and GPRS ───────────────────────────────────
  sendAT("AT+CIPCLOSE", 2000);
  sendAT("AT+CIPSHUT", 2000);

  return sent;
}

void wifi_begin() {
  Serial.print(F("[WiFi] Connecting to "));
  Serial.println(WIFI_SSID);
  WiFi.mode(WIFI_STA);
  WiFi.begin(WIFI_SSID, WIFI_PASS);
}

bool wifi_ensure() {
  if (WiFi.status() == WL_CONNECTED) return true;
  Serial.println(F("[WiFi] Reconnecting..."));
  WiFi.begin(WIFI_SSID, WIFI_PASS);
  unsigned long start = millis();
  while (WiFi.status() != WL_CONNECTED && millis() - start < 10000) delay(500);
  return WiFi.status() == WL_CONNECTED;
}

bool mqtt_ensure() {
  if (mqttClient.connected()) return true;
  mqttClient.setServer(MQTT_BROKER, MQTT_PORT);
  char clientId[32];
  snprintf(clientId, sizeof(clientId), "%s_%lu", DEVICE_ID, millis() % 10000);
  Serial.print(F("[MQTT] Connecting..."));
  bool ok = mqttClient.connect(clientId);
  if (ok) Serial.println(F(" OK"));
  else {
    Serial.print(F(" FAIL rc="));
    Serial.println(mqttClient.state());
  }
  return ok;
}

void mqtt_publish(const char* topic, const char* payload) {
  // ── Primary: WiFi + PubSubClient ────────────────────────────────
  if (wifi_ensure() && mqtt_ensure()) {
    mqttClient.setBufferSize(512);
    if (mqttClient.publish(topic, payload)) {
      Serial.print(F("[MQTT/WiFi] → "));
      Serial.println(topic);
      return;
    }
    Serial.println(F("[MQTT/WiFi] Publish failed — trying GSM GPRS"));
  } else {
    Serial.println(F("[MQTT/WiFi] Unavailable — trying GSM GPRS"));
  }

  // ── Fallback: GSM GPRS raw TCP MQTT ─────────────────────────────
  gsm_mqtt_publish(topic, payload);
}

void buildJSON(char* buf, size_t len, const char* alert_type = nullptr) {
  // Timestamp from NEO-6M GPS (UTC time-of-day); fall back to uptime counter.
  unsigned long ts;
  if (gps.time.isValid()) {
    ts = gps.time.hour() * 3600UL + gps.time.minute() * 60UL + gps.time.second();
  } else {
    ts = millis() / 1000;
  }

  const char* motStr = "IDLE";
  if (currentMotion == MOTION_FALL) motStr = "FALL";
  else if (currentMotion == MOTION_COLLISION) motStr = "COLLISION";
  else if (currentMotion == MOTION_GESTURE) motStr = "GESTURE";

  if (alert_type) {
    snprintf(buf, len,
             "{\"ts\":%lu,\"type\":\"%s\","
             "\"hr\":%.0f,\"spo2\":%d,\"temp\":%.1f,"
             "\"lat\":%.6f,\"lng\":%.6f,\"gps_ok\":%s,"
             "\"motion\":\"%s\",\"sos\":%s,"
             "\"bat\":%d,\"sig\":%d}",
             ts, alert_type, bpmDisplay, spo2Value, (double)bodyTemp,
             (double)gpsLat, (double)gpsLon, gpsFix ? "true" : "false",
             motStr, panicActive ? "true" : "false",
             batPercent, gsmSignalBars);
  } else {
    snprintf(buf, len,
             "{\"ts\":%lu,"
             "\"hr\":%.0f,\"spo2\":%d,\"temp\":%.1f,"
             "\"lat\":%.6f,\"lng\":%.6f,\"gps_ok\":%s,"
             "\"motion\":\"%s\",\"sos\":%s,"
             "\"bat\":%d,\"sig\":%d}",
             ts, bpmDisplay, spo2Value, (double)bodyTemp,
             (double)gpsLat, (double)gpsLon, gpsFix ? "true" : "false",
             motStr, panicActive ? "true" : "false",
             batPercent, gsmSignalBars);
  }
}

