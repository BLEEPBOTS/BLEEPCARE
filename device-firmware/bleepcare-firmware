// ═══════════════════════════════════════════
//  LOOP
// ═══════════════════════════════════════════
void loop() {

  if (mqttClient.connected()) mqttClient.loop();

  static unsigned long lastMpuRead = 0;
  if (millis() - lastMpuRead >= 20) {
    lastMpuRead = millis();
    updateMotion();
  }

  static unsigned long lastPanicBeep = 0;
  bool buttonPressed = (digitalRead(PANIC_PIN) == LOW);

  if (buttonPressed) {
    if (!panicHolding) {
      panicHolding = true;
      panicPressTime = millis();
    }
    unsigned long held = millis() - panicPressTime;
    int countdown = 3 - (int)(held / 1000);
    if (countdown < 0) countdown = 0;
    if (countdown != lastCountdown) {
      lastCountdown = countdown;
      updateSOSStatus(false, countdown);
    }
    if (held >= PANIC_HOLD_MS && !panicActive) {
      panicActive = true;
      Serial.println("!! SOS ACTIVATED !!");
      beep(3, 300, 150);
      updateSOSStatus(true, 0);
      mqtt_publish_alert("SOS");
      gsm_send_sos_alert();  // SOS is NEVER stability-gated
    }
  } else {
    if (panicHolding && !panicActive) updateSOSStatus(false, 0);
    panicHolding = false;
    lastCountdown = -1;
  }

  if (panicActive && millis() - lastPanicBeep >= 5000) {
    lastPanicBeep = millis();
    beep(1, 500, 0);
  }

  for (int i = 0; i < BUFFER_LEN; i++) {
    while (!heartSensor.available()) {
      heartSensor.check();
      feedGPS();
      if (millis() - lastMpuRead >= 20) {
        lastMpuRead = millis();
        updateMotion();
      }
    }
    redBuffer[i] = heartSensor.getRed();
    irBuffer[i] = heartSensor.getIR();
    heartSensor.nextSample();
    feedGPS();
  }

  // wristOn assigned after buffer is filled
  wristOn = irBuffer[BUFFER_LEN - 1] > WRIST_ON_IR_THRESHOLD;

  // Detect wrist-on transition and reset stability counter
  if (!lastWristOnState && wristOn) {
    stableSampleCount = 0;
    measurementStable = false;
    Serial.println("[STABILITY] Measurement started - stabilizing...");
  }
  lastWristOnState = wristOn;

  static unsigned long lastBatRead = 0;
  if (millis() - lastBatRead >= 300000) {
    lastBatRead   = millis();
    if (batPercent > 0) batPercent--;
    gsmSignalBars = random(2, 5);
  }
  static unsigned long lastTempRead = 0;

  if (wristOn) {

    // ══════════════════════════════════════════
    //  HEART RATE + SpO2 PROCESSING
    // ══════════════════════════════════════════
    maxim_heart_rate_and_oxygen_saturation(
      irBuffer, BUFFER_LEN, redBuffer,
      &spo2Value, &validSPO2, &heartRate, &validHeartRate);

    // Only accept physiologically plausible raw values
    bool hrValid   = validHeartRate && heartRate > 40 && heartRate < 200;
    bool spo2Valid = validSPO2 && spo2Value >= 70 && spo2Value <= 100;

    if (hrValid && spo2Valid) {
      // Feed rolling average buffers
      hrHistory[smoothIdx]   = heartRate;
      spo2History[smoothIdx] = spo2Value;
      smoothIdx = (smoothIdx + 1) % SMOOTH_LEN;
      if (smoothFilled < SMOOTH_LEN) smoothFilled++;

      // Compute smoothed values
      float hrSum = 0; int spo2Sum = 0;
      for (int i = 0; i < smoothFilled; i++) {
        hrSum   += hrHistory[i];
        spo2Sum += spo2History[i];
      }
      hrSmoothed   = hrSum / smoothFilled;
      spo2Smoothed = spo2Sum / smoothFilled;

      bpmDisplay = hrSmoothed;
      spo2Value  = spo2Smoothed;

      stableSampleCount++;
      if (stableSampleCount >= STABLE_SAMPLES_REQUIRED && !measurementStable) {
        measurementStable = true;
        Serial.println(F("[STABILITY] Readings stable — alerts enabled"));
      }
    } else {
      // Bad reading — gradually degrade rather than instant reset
      if (!hrValid && !spo2Valid) {
        stableSampleCount = max(0, stableSampleCount - 1);
        if (stableSampleCount == 0) {
          measurementStable = false;
          smoothFilled = 0;
          smoothIdx    = 0;
        }
      }
      // Keep last good smoothed value on display — don't zero out on one glitch
    }

    // ══════════════════════════════════════════
    //  TEMPERATURE
    // ══════════════════════════════════════════
    if (millis() - lastTempRead >= 2000) {
      lastTempRead = millis();
      bodyTemp = readLM35();
      if (irBuffer[BUFFER_LEN - 1] > 80000) {
        updateTemp(bodyTemp);
        if (bodyTemp >= TEMP_HIGH_FEVER) {
          Serial.print(F("HIGH FEVER: "));
          Serial.println(bodyTemp);
          beep(2, 200, 100);
        }
      }
    }

  } else {
    // Wrist removed — clear everything
    bpmDisplay = 0; spo2Value = 0;
    validSPO2 = 0; validHeartRate = 0;
    heartRate = 0; bodyTemp = 0;
    stableSampleCount = 0; measurementStable = false;
    smoothFilled = 0; smoothIdx = 0;
    consecBadCount = 0;
    hrSmoothed = 0; spo2Smoothed = 0;
    bodyTemp = 0;

    // Reset stability when wrist is removed
    stableSampleCount = 0;
    measurementStable = false;

    updateBPM(0);
    updateSpO2(0);
    updateTemp(0);
  }

  feedGPS();

  // ═══════════════════════════════════════════
  //  GPS — NEO-6M hardware module only
  // ═══════════════════════════════════════════
  if (gps.location.isValid()) {
    gpsFix = true;
    gpsLat = gps.location.lat();
    gpsLon = gps.location.lng();
  } else {
    gpsFix = false;
  }
  if (gps.altitude.isValid())   gpsAlt  = gps.altitude.meters();
  if (gps.satellites.isValid()) gpsSats = gps.satellites.value();
  if (gps.time.isValid()) {
    gpsHour = gps.time.hour();
    gpsMin  = gps.time.minute();
    gpsSec  = gps.time.second();
  }

  if ((int)bpmDisplay != (int)lastBpm) {
    lastBpm = bpmDisplay;
    updateBPM(bpmDisplay);
  }

  int cleanSpo2 = (spo2Value >= 70 && spo2Value <= 100) ? spo2Value : 0;
  if (cleanSpo2 != lastSpo2) {
    lastSpo2 = cleanSpo2;
    updateSpO2(cleanSpo2);
  }

  if (gpsFix != lastFix || gpsLat != lastLat || gpsLon != lastLon) {
    lastFix = gpsFix;
    lastLat = gpsLat;
    lastLon = gpsLon;
    updateGPSLocation(gpsLat, gpsLon);
  }
  if (abs(gpsSats - lastSats) > 1 || abs(gpsAlt - lastAlt) > 5) {
    lastSats = gpsSats;
    lastAlt = gpsAlt;
    updateGPSExtra(gpsAlt, gpsSats);
  }
  if (gpsSec != lastSec) {
    lastSec = gpsSec;
    updateGPSTime(gpsHour, gpsMin, gpsSec);
  }
  if (currentMotion != lastMotion) {
    lastMotion = currentMotion;
    updateMotionDisplay(currentMotion);
  }

  mqtt_publish_vitals();
  mqtt_check_thresholds();

  static unsigned long lastConnCheck = 0;
  if (millis() - lastConnCheck >= 10000) {
    lastConnCheck = millis();
    mqttReady = mqttClient.connected();
    updateConnStatus(WiFi.status() == WL_CONNECTED, mqttReady);
  }

  int eatH = (gpsHour + 3) % 24;
  Serial.print("BPM:");
  Serial.print(bpmDisplay);
  Serial.print(" SpO2:");
  Serial.print(cleanSpo2);
  Serial.print(" TEMP:");
  Serial.print(bodyTemp, 1);
  Serial.print(" LAT:");
  Serial.print(gpsLat, 5);
  Serial.print(" LON:");
  Serial.print(gpsLon, 5);
  Serial.print(" SAT:");
  Serial.print(gpsSats);
  Serial.print(" FIX:");
  Serial.print(gpsFix);
  Serial.print(" EAT:");
  Serial.print(eatH);
  Serial.print(":");
  Serial.print(gpsMin);
  Serial.print(":");
  Serial.print(gpsSec);
  Serial.print(" SOS:");
  Serial.print(panicActive);
  Serial.print(" WiFi:");
  Serial.print(WiFi.status() == WL_CONNECTED ? "Y" : "N");
  Serial.print(" MQTT:");
  Serial.print(mqttReady ? "Y" : "N");
  Serial.print(" STABLE:");
  Serial.print(measurementStable ? "Y" : "N");
  Serial.print(" MOT:");
  switch (currentMotion) {
    case MOTION_IDLE: Serial.println("IDLE"); break;
    case MOTION_GESTURE: Serial.println("GESTURE"); break;
    case MOTION_FALL: Serial.println("FALL"); break;
    case MOTION_COLLISION: Serial.println("COLLISION"); break;
  }
}

