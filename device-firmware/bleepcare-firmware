// ═══════════════════════════════════════════
//  BUZZER
// ═══════════════════════════════════════════
void beep(int times, int onMs, int offMs) {
  for (int i = 0; i < times; i++) {
    digitalWrite(BUZZER_PIN, HIGH);
    delay(onMs);
    digitalWrite(BUZZER_PIN, LOW);
    if (i < times - 1) delay(offMs);
  }
}

// ═══════════════════════════════════════════
//  TEMPERATURE READ
// ═══════════════════════════════════════════
float readLM35() {
  analogSetPinAttenuation(LM35_PIN, ADC_11db);
  delay(10);
  long sum = 0;
  for (int i = 0; i < 20; i++) {
    sum += analogRead(LM35_PIN);
    delay(5);
  }
  float raw = sum / 20.0;
  float voltage = (raw / 4095.0) * 3300.0;
  return (voltage / 10.0) + 32.5;
}

// ═══════════════════════════════════════════
//  MOTION ALGORITHM
// ═══════════════════════════════════════════
long getAccelMagnitude(int16_t ax, int16_t ay, int16_t az) {
  float fx = ax, fy = ay, fz = az;
  return (long)sqrt(fx * fx + fy * fy + fz * fz);
}

void updateMotion() {
  int16_t ax, ay, az, gx, gy, gz;
  mpu.getMotion6(&ax, &ay, &az, &gx, &gy, &gz);

  long mag = getAccelMagnitude(ax, ay, az);
  long deviation = abs(mag - 16384L);
  unsigned long now = millis();

  if (mag < FREEFALL_THRESHOLD) {
    if (!inFreeFall) {
      inFreeFall = true;
      freeFallStartMs = now;
      freeFallArmed = false;
    } else if (!freeFallArmed && (now - freeFallStartMs) >= FREEFALL_MS) freeFallArmed = true;
  } else {
    if (inFreeFall) {
      freeFallEndMs = now;
      inFreeFall = false;
    }
  }

  if (freeFallArmed && !inFreeFall) {
    if ((now - freeFallEndMs) <= IMPACT_WINDOW_MS) {
      if (mag > IMPACT_THRESHOLD) {
        currentMotion = MOTION_FALL;
        motionEventTime = now;
        freeFallArmed = false;
        Serial.println("[FALL DETECTED]");
        beep(3, 200, 100);
        mqtt_publish_alert("FALL");
        gsm_send_sos_alert();  // SOS is NEVER stability-gated
        return;
      }
    } else freeFallArmed = false;
  }

  if (!freeFallArmed && mag > COLLISION_THRESHOLD) {
    if (currentMotion != MOTION_FALL || (now - motionEventTime) > EVENT_HOLD_MS) {
      currentMotion = MOTION_COLLISION;
      motionEventTime = now;
      Serial.println("[COLLISION DETECTED]");
      beep(2, 150, 100);
      mqtt_publish_alert("COLLISION");
      return;
    }
  }

  if ((currentMotion == MOTION_FALL || currentMotion == MOTION_COLLISION)
      && (now - motionEventTime) < EVENT_HOLD_MS) return;

  if (deviation > GESTURE_THRESHOLD) {
    currentMotion = MOTION_GESTURE;
    motionEventTime = now;
  } else if (deviation <= IDLE_THRESHOLD) currentMotion = MOTION_IDLE;
}

