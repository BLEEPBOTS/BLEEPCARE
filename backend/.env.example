# Server
PORT=3500

# MongoDB
MONGODB_URL=mongodb://127.0.0.1:27017/bleepcare

# Better Auth (required — library reads BETTER_AUTH_SECRET from env internally)
BETTER_AUTH_URL=http://localhost:3500
BETTER_AUTH_SECRET=change-me-to-a-random-string

# CORS
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=dev

# also used in mongodb.js connection logic
ENV=dev

# MQTT (device log ingestion — public broker, no encryption in prototype)
MQTT_BROKER_URL=mqtt://broker.hivemq.com:1883
MQTT_TOPIC_PREFIX=bleepcare
ENABLE_MQTT=false

# Vercel deployment (leave unset for local dev)
# VERCEL=true
